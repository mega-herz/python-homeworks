      "source": [
        "import pandas as pd\n",
        "\n",
        "# Load data from file\n",
        "df_raw = pd.read_csv('train.csv.zip')\n",
        "\n",
        "# Transform Month in datetime format and make it as index\n",
        "df_raw['date'] = pd.to_datetime(df_raw['date'])\n",
        "df_raw.set_index('date', inplace=True)\n",
        "\n",
        "# Data info\n",
        "print(f'Shape of data: {df_raw.shape}')\n",
        "display(df_raw.head(10))\n",
        "display(df_raw.info())"
      ]
    },
