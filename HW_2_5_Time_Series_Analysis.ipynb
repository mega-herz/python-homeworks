        }
      ],
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "df_grid = df_raw.reset_index() # make 'date' standard column, so data can be splitted by 'item'\n",
        "\n",
        "# Grid layout: 5 columns in a row\n",
        "grid = sns.FacetGrid(df_grid, col=\"item\", col_wrap=5, height=2, aspect=1.5)\n",
        "\n",
        "# Produce lineplots\n",
        "grid.map_dataframe(sns.lineplot, x=\"date\", y=\"sales\", errorbar=None) # lineplot: calculates mean of all values from 10 shops (on the same date) for the item\n",
        "\n",
        "# Set descriptions\n",
        "grid.set_titles(\"item{col_name}\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "tqmhMM1vrZFB"
      },
      "source": [
        "На графіках видно зростаюча тенденція/тренд у продажах для всіх `item`: від слабкого зростання до помірного. За рівнем кількості продажів товари можна поділити на три базові групи: менш популярні (low sales), помірно популярні (moderate sales) та дуже популярні (high sales)  Також дані по продажам товарів мають сильно виражену сезонність. Спостерігається певна синхронність у сезонності всіх товарів: продажі досягають свого мінімуму у зимні місяці і максимуму у літні, навесні і восени продажі зростають або спрадають відповідно.\n",
        "\n",
        "Розглянемо продажі та їх довірчий інтервал (показує розкид значень продажів по всіх магазинах) для декількох товарів, що відрізняються за їх популярністю: менш популярний (low sales) - напр. `item1`, помірно популярний (moderate sales) - напр. `item9` та дуже популярний (high sales) - напр. `item18`."
      ]
    },
